NODE_ENV=production
PORT=5001
PUBLIC_APP_URL=https://your-domain.com

# Security: generate long random values before launch.
JWT_SECRET=change_this_to_a_long_random_value
REFRESH_SECRET=change_this_to_a_different_long_random_value

# SQLite is acceptable for demos and small pilots. Move to managed Postgres for scale.
SQLITE_FILE=./eic-enterprise.db

# Admins allowed to view demo requests.
ADMIN_EMAILS=innoengola305@gmail.com,eicenterprise@gmail.com
NOTIFY_EMAIL=innoengola305@gmail.com

# Email notifications.
DISABLE_EMAIL=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-password

# Stripe live mode. Use sk_live/pk_live only after Stripe account activation and webhook setup.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Adapter fallbacks. Keep true for demos/sandbox environments without provider credentials.
EIC_MOCK_PROVIDERS=true

# Settlement banking. Store real values only in your server/Vercel environment, never in frontend code.
CENTENARY_ACCOUNT=replace_me_server_only
CENTENARY_NAME=EIC Enterprise Ltd
CENTENARY_BANK=Centenary Bank Uganda
CENTENARY_BRANCH=replace_me_server_only
CENTENARY_CURRENCY=UGX

# Mobile money providers.
MTN_MOMO_SUBSCRIPTION_KEY=replace_me
MTN_MOMO_API_USER=replace_me
MTN_MOMO_API_KEY=replace_me
MTN_MOMO_ENV=sandbox
AIRTEL_CLIENT_ID=replace_me
AIRTEL_CLIENT_SECRET=replace_me
AIRTEL_ENV=sandbox
MPESA_CONSUMER_KEY=replace_me
MPESA_CONSUMER_SECRET=replace_me
MPESA_SHORTCODE=replace_me
MPESA_ENV=sandbox

# Flutterwave adapter.
FLUTTERWAVE_SECRET_KEY=replace_me
FLUTTERWAVE_PUBLIC_KEY=replace_me
FLUTTERWAVE_WEBHOOK_SECRET=replace_me
FLUTTERWAVE_ENV=sandbox

# URA EFRIS adapter.
URA_EFRIS_API_URL=https://replace-me.example
URA_EFRIS_TIN=replace_me
URA_EFRIS_DEVICE_NO=replace_me
URA_EFRIS_PRIVATE_KEY=replace_me
URA_EFRIS_ENV=sandbox

# ARIA AI. If absent, ARIA uses local intelligence and returns mode=local.
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-sonnet-4-20250514
